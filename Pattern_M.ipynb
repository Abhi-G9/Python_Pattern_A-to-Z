    "def M():\n",
    "    for row in range(7):\n",
    "        for col in range(7):\n",
    "            if col==0 or col==6 or ((row==col)and(col>0 and col<4))or(row==1 and col==5)or(row==2 and col==4):\n",
    "                print('*',end=' ')\n",
    "            else:   \n",
    "                print(' ',end=' ')\n",
    "        print()\n",
    "M()"
