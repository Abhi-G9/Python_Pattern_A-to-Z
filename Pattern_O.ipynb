    "def O():\n",
    "\n",
    "    for row in range(7):\n",
    "        for col in range(6):\n",
    "            if (col==0 or col==4) and (row!=0 and row!=6) or ((row==0 or row==6)and(col>0 and col<4)):\n",
    "                print('*',end=' ')\n",
    "            else:\n",
    "                print('',end='  ')\n",
    "        print()\n",
    "O()"
