   "source": [
    "def N():\n",
    "    for row in range(7):\n",
    "        for col in range(7):\n",
    "            if col==0 or col==6 or (row==col and (col>0 and col<6)):\n",
    "                print('*',end=' ')\n",
    "            else:\n",
    "                print(' ',end=' ')\n",
    "        print()\n",
    "N()"
   ]
